# 🎫 Event Planner - Ticket Generator Service Environment Configuration
#
# 📋 GUIDE D'UTILISATION :
# 1. Copier ce fichier en .env.local pour le développement
# 2. Copier ce fichier en .env pour la production
# 3. Remplacer les valeurs par défaut par vos vraies clés
# 4. NE JAMAIS COMMITTER le fichier .env contenant des secrets !

# ===========================================
# 🚀 SERVEUR & ENVIRONNEMENT
# ===========================================
PORT=3004
# 🎯 Port d'écoute du service (doit être unique par service)
NODE_ENV=development
# 🌍 Environnement : development | staging | production

# ===========================================
# 🗄️ BASE DE DONNÉES POSTGRESQL
# ===========================================
DB_HOST=localhost
# 🏠 Hôte de la base de données (localhost en dev, RDS endpoint en prod)
DB_PORT=5432
# 🚪 Port PostgreSQL (5432 par défaut)
DB_NAME=event_planner_ticket_generator
# 📊 Nom de la base de données (préfixe event_planner_ recommandé)
DB_USER=postgres
# 👤 Utilisateur PostgreSQL (créer un utilisateur dédié en prod)
DB_PASSWORD=postgres
# 🔐 Mot de passe PostgreSQL (utiliser un mot de passe fort en prod)
DB_SSL=false
# 🔒 Connexion SSL (true en production avec RDS)

# Pool de connexions pour optimiser les performances
DB_POOL_MIN=2
# 🔢 Nombre minimum de connexions dans le pool
DB_POOL_MAX=20
# 🔢 Nombre maximum de connexions dans le pool
DB_POOL_IDLE_TIMEOUT=30000
# ⏰ Timeout d'inactivité des connexions (ms)
DB_CONNECTION_TIMEOUT=2000
# ⏰ Timeout de connexion (ms)

# Bootstrap automatique de la base de données
# ⚠️  DÉSACTIVÉ PAR DÉFAUT EN PRODUCTION POUR SÉCURITÉ
# ✅ true : Crée automatiquement les tables et index au démarrage
# ❌ false : Nécessite une migration manuelle en production
DB_AUTO_BOOTSTRAP=false

# ===========================================
# 🔐 QR CODE CONFIGURATION
# ===========================================
# Clé pour signature cryptographique des QR codes
# ⚠️ IMPORTANT: Utiliser une clé sécurisée en production
# 🔑 Générer : openssl rand -base64 32
QR_SECRET_KEY=ticket-qr-secret-key-2026
# 🔐 Clé secrète pour signer les QR codes (anti-fraude)

# Configuration QR code avancée
QR_ALGORITHM=HS256
# 🛠️ Algorithme de signature pour QR codes (HS256 recommandé)
QR_EXPIRY_HOURS=24
# ⏰ Durée de validité des QR codes (heures)
QR_MAX_VALIDITY=86400
# ⏰ Durée maximale de validité en secondes (86400 = 24h)
QR_MAX_SIZE=4096
# 📏 Taille maximale du QR code en octets

# ===========================================
# 🌐 INTER-SERVICES COMMUNICATION
# ===========================================
# Token partagé pour communication entre services
# 🔑 Générer : openssl rand -base64 32 (doit être identique partout)
SHARED_SERVICE_TOKEN=shared-service-token-abcdef12345678901234567890
# 🔐 Token pour authentifier les communications inter-services

# URLs des autres services (pour health checks et communication)
AUTH_SERVICE_URL=http://localhost:3000
# 🔐 URL du service d'authentification
CORE_SERVICE_URL=http://localhost:3001
# 🎯 URL du service principal
NOTIFICATION_SERVICE_URL=http://localhost:3002
# 📧 URL du service de notifications
PAYMENT_SERVICE_URL=http://localhost:3003
# 💳 URL du service de paiements
SCAN_VALIDATION_SERVICE_URL=http://localhost:3005
# 🔍 URL du service de validation

# Timeout pour les appels HTTP inter-services
INTER_SERVICE_TIMEOUT=30000
# ⏰ Timeout par défaut (30000ms = 30 secondes)
INTER_SERVICE_RETRY_ATTEMPTS=3
# 🔢 Nombre de tentatives de retry
INTER_SERVICE_RETRY_DELAY=1000
# ⏰ Délai entre les retries (1000ms = 1 seconde)

# ===========================================
# 💾 CACHE REDIS
# ===========================================
REDIS_HOST=localhost
# 🏠 Hôte Redis (localhost en dev, ElastiCache endpoint en prod)
REDIS_PORT=6379
# 🚪 Port Redis (6379 par défaut)
REDIS_PASSWORD=
# 🔐 Mot de passe Redis (optionnel en dev, requis en prod)
REDIS_DB=4
TICKET_GENERATION_QUEUE_DB=4
TICKET_GENERATION_QUEUE_PASSWORD=
# 📊 Numéro de la base Redis (4 pour Ticket Generator Service)

# Configuration du cache
CACHE_TTL=3600
# ⏰ Durée de vie du cache en secondes (3600 = 1 heure)
CACHE_MAX_KEYS=10000
# 🔢 Nombre maximum de clés en cache

# ===========================================
# 📄 PDF GENERATION CONFIGURATION
# ===========================================
PDF_TEMPLATE_DIR=./templates
# 📁 Répertoire des templates PDF
PDF_OUTPUT_DIR=./generated
# 📁 Répertoire de sortie des PDF générés
PDF_MAX_BATCH_SIZE=100
# 🔢 Nombre maximum de tickets générés en batch

# Options PDF par défaut
PDF_DEFAULT_FORMAT=A4
# 📄 Format PDF par défaut (A4, A3, Letter)
PDF_DEFAULT_ORIENTATION=portrait
# 📐 Orientation par défaut (portrait, landscape)
PDF_DEFAULT_MARGIN=20
# 📏 Marge par défaut en millimètres
PDF_QUALITY=high
# 🎨 Qualité PDF (low, medium, high)

# Configuration avancée PDF
PDF_COMPRESSION=true
# 🗜️ Activer la compression PDF
PDF_PASSWORD_PROTECTED=false
# 🔐 Protéger les PDF avec mot de passe
PDF_WATERMARK_ENABLED=false
# 🌊 Activer le filigrane sur les PDF

# ===========================================
# 🎫 QR CODE TECHNICAL CONFIGURATION
# ===========================================
QR_CODE_SIZE=300
# 📏 Taille du QR code en pixels
QR_ERROR_CORRECTION=M
# 🛠️ Niveau de correction d'erreur (L, M, Q, H)
QR_MARGIN=4
# 📏 Marge du QR code (pixels)
QR_FOREGROUND_COLOR=000000
# 🎨 Couleur de premier plan (hexadécimal)
QR_BACKGROUND_COLOR=FFFFFF
# 🎨 Couleur de fond (hexadécimal)

# Options avancées QR code
QR_LOGO_ENABLED=false
# 🖼️ Activer l'insertion de logo dans QR code
QR_LOGO_PATH=./assets/logo.png
# 🖼️ Chemin du logo pour QR code
QR_CUSTOM_DATA_ENABLED=true
# 📊 Activer les données personnalisées dans QR code

# ===========================================
# 📁 STORAGE CONFIGURATION
# ===========================================
TICKETS_STORAGE_PATH=./tickets
# 📁 Chemin de stockage des tickets générés
TEMP_PATH=./temp
# 📁 Chemin des fichiers temporaires
MAX_FILE_SIZE=5MB
# 📏 Taille maximale des fichiers (5MB par défaut)
CLEANUP_TEMP_FILES_HOURS=1
# 🗑️ Nettoyer les fichiers temporaires après (heures)

# Configuration du stockage cloud (optionnel)
ENABLE_CLOUD_STORAGE=false
# ☁️ Activer le stockage cloud (AWS S3, Google Cloud, etc.)
CLOUD_STORAGE_PROVIDER=aws
# ☁️ Fournisseur cloud (aws, gcp, azure)
CLOUD_STORAGE_BUCKET=event-planner-tickets
# 📦 Nom du bucket de stockage

# ===========================================
# ⚡ PERFORMANCE & RATE LIMITING
# ===========================================
# Rate limiting technique
RATE_LIMIT_WINDOW_MS=900000
# ⏰ Fenêtre de temps pour le rate limiting (900000ms = 15 minutes)
RATE_LIMIT_MAX_REQUESTS=1000
# 🔢 Nombre max de requêtes par fenêtre (global)

# Concurrency settings
MAX_CONCURRENT_GENERATIONS=10
# 🔢 Nombre maximum de générations simultanées
GENERATION_TIMEOUT=30000
# ⏰ Timeout pour la génération d'un ticket (30 secondes)
BATCH_PROCESSING_DELAY=100
# ⏰ Délai entre les traitements batch (100ms)

# Configuration mémoire
MAX_MEMORY_USAGE=512mb
# 🧠 Utilisation mémoire maximale (512MB par défaut)
TEMP_DIR_MAX_SIZE=1gb
# 📁 Taille maximale du répertoire temporaire

# ===========================================
# 🗂️ NETTOYAGE AUTOMATIQUE
# ===========================================
CLEANUP_ENABLED=true
# ✅ Activer le nettoyage automatique
CLEANUP_INTERVAL=86400000
# ⏰ Intervalle de nettoyage (86400000ms = 24 heures)
CLEANUP_RETENTION_DAYS=30
# 📅 Durée de rétention des fichiers (jours)
TEMP_FILE_CLEANUP_DELAY=3600000
# ⏰ Délai avant nettoyage des fichiers temporaires (3600000ms = 1 heure)

# ===========================================
# 🎨 TEMPLATES CONFIGURATION
# ===========================================
TEMPLATES_PATH=./templates
# 📁 Chemin des templates de tickets
DEFAULT_TEMPLATE=standard
# 🎭 Template par défaut pour les tickets
CUSTOM_TEMPLATES_ENABLED=true
# ✅ Activer les templates personnalisés

# Types de templates supportés
SUPPORTED_TEMPLATE_FORMATS=html,pug,handlebars
# 📄 Formats de templates supportés
TEMPLATE_CACHE_ENABLED=true
# 🗄️ Activer le cache des templates
TEMPLATE_VALIDATION_ENABLED=true
# ✅ Valider les templates avant utilisation

# ===========================================
# 🔄 BATCH PROCESSING
# ===========================================
BATCH_SIZE=100
# 🔢 Taille par défaut des lots de traitement
BATCH_TIMEOUT_MINUTES=30
# ⏰ Timeout pour le traitement batch (30 minutes)
ENABLE_ASYNC_PROCESSING=true
# ✅ Activer le traitement asynchrone
BATCH_RETRY_ATTEMPTS=3
# 🔢 Nombre de tentatives de retry pour les batchs
BATCH_RETRY_DELAY=5000
# ⏰ Délai entre les retries batch (5000ms = 5 secondes)

# ===========================================
# 📝 LOGGING
# ===========================================
LOG_LEVEL=info
# 📊 Niveau de log : error | warn | info | debug
LOG_FILE_PATH=logs
# 📁 Chemin des fichiers de log
LOG_MAX_SIZE=20MB
# 📏 Taille maximale d'un fichier de log
LOG_MAX_FILES=14d
# 📅 Durée de rétention des logs (14 jours recommandé)
LOG_FORMAT=json
# 📄 Format des logs (json, text)

# Activer les logs structurés
ENABLE_STRUCTURED_LOGS=true
# 📊 Activer les logs au format JSON
ENABLE_REQUEST_LOGGING=true
# 📝 Activer les logs des requêtes HTTP
ENABLE_GENERATION_LOGGING=true
# 🎫 Activer les logs détaillés de génération

# ===========================================
# 📊 MONITORING
# ===========================================
ENABLE_METRICS=true
# 📈 Activer les métriques Prometheus
METRICS_PORT=9094
# 🚪 Port pour les métriques (doit être unique)
ENABLE_HEALTH_CHECKS=true
# ✅ Activer les health checks détaillés
ENABLE_PERFORMANCE_MONITORING=true
# 📈 Activer le monitoring des performances

# Health checks
HEALTH_CHECK_INTERVAL=30000
# ⏰ Intervalle des health checks (30000ms = 30 secondes)
HEALTH_CHECK_TIMEOUT=5000
# ⏰ Timeout des health checks (5000ms = 5 secondes)

# ===========================================
# 🚦 RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
# ⏰ Fenêtre de temps pour le rate limiting (900000ms = 15 minutes)
RATE_LIMIT_MAX_REQUESTS=500
# 🔢 Nombre max de requêtes par fenêtre (global)
TICKET_GENERATION_RATE_LIMIT=100
# 🎫 Limite pour la génération de tickets
BATCH_GENERATION_RATE_LIMIT=10
# 📦 Limite pour la génération batch

# Rate limiting spécifique par endpoint
TICKET_PREVIEW_RATE_LIMIT=50
# 👁️ Limite pour l'endpoint de preview
TEMPLATE_LIST_RATE_LIMIT=200
# 📋 Limite pour la liste des templates

# ===========================================
# 📊 TICKET STATISTICS
# ===========================================
ENABLE_DETAILED_LOGGING=true
# 📊 Activer les logs détaillés pour les statistiques
STATISTICS_RETENTION_DAYS=90
# 📅 Durée de rétention des statistiques (jours)
GENERATION_REPORT_ENABLED=true
# 📊 Activer le rapport de génération
ENABLE_REAL_TIME_STATS=true
# 📈 Activer les statistiques en temps réel

# ===========================================
# 🛡️ ANTI-FRAUD
# ===========================================
ENABLE_DUPLICATE_CHECK=true
# ✅ Activer la détection de doublons
MAX_TICKETS_PER_USER_PER_EVENT=10
# 🔢 Maximum de tickets par utilisateur par événement
TICKET_NUMBER_LENGTH=8
# 🔢 Longueur du numéro de ticket
TICKET_PREFIX=EVT
# 🎫 Préfixe pour les numéros de tickets

# Configuration anti-fraude avancée
FRAUD_DETECTION_ENABLED=true
# 🛡️ Activer la détection de fraude
SUSPICIOUS_PATTERN_DETECTION=true
# 🔍 Activer la détection de patterns suspects
BLACKLIST_ENABLED=false
# 🚫 Activer la blacklist d'utilisateurs

# ===========================================
# 🛡️ SÉCURITÉ
# ===========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3004
# 🌐 Origines autorisées pour CORS (séparer par des virgules)
ENABLE_IP_WHITELIST=false
# ✅ Activer le whitelist d'IPs
ALLOWED_IPS=127.0.0.1,::1
# 🌐 Adresses IP autorisées (séparer par des virgules)
ENABLE_REQUEST_VALIDATION=true
# ✅ Activer la validation stricte des requêtes

# Configuration sécurité avancée
ENABLE_RATE_LIMITING=true
# 🚦 Activer le rate limiting
ENABLE_INPUT_SANITIZATION=true
# 🧹 Activer la sanitisation des entrées
ENABLE_FILE_VALIDATION=true
# ✅ Activer la validation stricte des fichiers

# ===========================================
# 🧪 TESTS & DÉVELOPPEMENT
# ===========================================
ENABLE_MOCK_SERVICES=false
# 🧪 Activer les services mockés pour les tests
ENABLE_DEBUG_MODE=false
# 🐛 Activer le mode debug (informations supplémentaires)
ENABLE_PERFORMANCE_PROFILING=false
# 📈 Activer le profiling des performances (uniquement en dev)

# Configuration de test
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/event_planner_tickets_test
# 🧪 URL de la base de données de test
TEST_REDIS_URL=redis://localhost:6379/15
# 🧪 URL Redis pour les tests
TEST_TIMEOUT=10000
# ⏰ Timeout pour les tests (10 secondes)

# Mock configuration
MOCK_QR_GENERATION=true
# 🎫 Mock la génération de QR codes en test
MOCK_PDF_GENERATION=true
# 📄 Mock la génération de PDF en test
MOCK_STORAGE=true
# 💾 Mock le stockage en test
